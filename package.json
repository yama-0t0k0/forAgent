{
    "name": "engineer-registration-app-yama",
    "version": "1.0.0",
    "private": true,
    "description": "Modular Monolith Monorepo for Engineer Registration App",
    "workspaces": [
        "apps/*/expo_frontend",
        "shared/*"
    ],
    "scripts": {
        "start:admin": "bash scripts/start_expo.sh admin_app",
        "start:individual": "bash scripts/start_expo.sh individual_user_app",
        "start:corporate": "bash scripts/start_expo.sh corporate_user_app",
        "start:job_description": "bash scripts/start_expo.sh job_description",
        "start:fmjs": "bash scripts/start_expo.sh fmjs",
        "push": "bash githooks/safe_push.sh"
    },
    "dependencies": {
        "@react-native-community/datetimepicker": "8.4.4",
        "@react-navigation/bottom-tabs": "^7.8.12",
        "@react-navigation/material-top-tabs": "^7.4.9",
        "@react-navigation/native": "^7.1.25",
        "@react-navigation/native-stack": "^7.2.0",
        "expo": "~54.0.29",
        "expo-asset": "~12.0.12",
        "expo-constants": "~18.0.12",
        "expo-linking": "~8.0.11",
        "expo-status-bar": "~3.0.9",
        "expo-system-ui": "~6.0.9",
        "firebase": "^12.6.0",
        "firebase-admin": "^13.6.0",
        "react": "19.1.0",
        "react-native": "0.81.5",
        "react-native-pager-view": "6.9.1",
        "react-native-reanimated": "~4.1.1",
        "react-native-safe-area-context": "^5.6.2",
        "react-native-screens": "~4.16.0",
        "react-native-tab-view": "^4.2.0",
        "react-native-worklets": "npm:react-native-worklets-core@^1.6.2",
        "react-native-worklets-core": "^1.6.2"
    },
    "devDependencies": {
        "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
        "@babel/plugin-transform-template-literals": "^7.27.1",
        "@expo/ngrok": "^4.1.3",
        "@firebase/rules-unit-testing": "^5.0.0",
        "@testing-library/react-native": "^13.3.3",
        "babel-plugin-module-resolver": "^5.0.2",
        "babel-preset-expo": "~12.0.0",
        "jest": "^29.7.0",
        "jest-expo": "^54.0.16",
        "react-test-renderer": "^19.1.0"
    },
    "overrides": {
        "react-native-pager-view": "6.9.1"
    }
}
