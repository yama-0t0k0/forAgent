{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "functions": {
        "source": "apps/functions"
    },
    "emulators": {
        "auth": {
            "port": 9099
        },
        "firestore": {
            "port": 8080
        },
        "functions": {
            "port": 5001
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": true
    },
    "hosting": [
        {
            "target": "admin-app",
            "public": "apps/admin_app/expo_frontend/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "/firebase-web-authn-api",
                    "function": "ext-firebase-web-authn-api"
                },
                {
                    "source": "/api/matching/**",
                    "run": {
                        "serviceId": "matching-functions",
                        "region": "asia-northeast1"
                    }
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "lp-domain",
            "public": "apps/lp_app/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/.well-known/apple-app-site-association",
                    "headers": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "key": "Cache-Control",
                            "value": "no-store"
                        }
                    ]
                },
                {
                    "source": "/.well-known/assetlinks.json",
                    "headers": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "key": "Cache-Control",
                            "value": "no-store"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/matching/**",
                    "run": {
                        "serviceId": "matching-functions",
                        "region": "asia-northeast1"
                    }
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        },
        {
            "target": "lp-domain-dev",
            "public": "apps/lp_domain_hosting/public",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "headers": [
                {
                    "source": "/.well-known/apple-app-site-association",
                    "headers": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "key": "Cache-Control",
                            "value": "no-store"
                        }
                    ]
                },
                {
                    "source": "/.well-known/assetlinks.json",
                    "headers": [
                        {
                            "key": "Content-Type",
                            "value": "application/json"
                        },
                        {
                            "key": "Cache-Control",
                            "value": "no-store"
                        }
                    ]
                }
            ],
            "rewrites": [
                {
                    "source": "/api/matching/**",
                    "run": {
                        "serviceId": "matching-functions",
                        "region": "asia-northeast1"
                    }
                },
                {
                    "source": "/lp/**",
                    "destination": "/lp/index.html"
                }
            ]
        }
    ]
}
