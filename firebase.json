{
    "hosting": [
        {
            "target": "admin-app",
            "public": "apps/admin_app/expo_frontend/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        }
    ]
}