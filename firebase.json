{
    "firestore": {
        "rules": "firestore.rules"
    },
    "functions": {
        "source": "apps/functions"
    },
    "emulators": {
        "firestore": {
            "port": 8080
        },
        "ui": {
            "enabled": true
        },
        "singleProjectMode": true
    },
    "hosting": [
        {
            "target": "admin-app",
            "public": "apps/admin_app/expo_frontend/dist",
            "ignore": [
                "firebase.json",
                "**/.*",
                "**/node_modules/**"
            ],
            "rewrites": [
                {
                    "source": "/firebase-web-authn-api",
                    "function": "ext-firebase-web-authn-api"
                },
                {
                    "source": "**",
                    "destination": "/index.html"
                }
            ]
        }
    ]
}